<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:id="@+id/homePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_gutter"
        android:paddingTop="@dimen/spacing_medium"
        android:paddingEnd="@dimen/screen_gutter"
        android:paddingBottom="@dimen/spacing_small">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textColor="@color/app_text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:text="@string/home_description"
            android:textColor="@color/app_text_secondary"
            android:textSize="@dimen/text_body" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            app:cardBackgroundColor="@color/app_surface"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_medium">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_ready"
                    android:textColor="@color/app_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusDetailText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/device_count_zero"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="@dimen/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_medium"
            android:text="@string/scan_devices"
            android:textSize="@dimen/text_button"
            app:cornerRadius="24dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/deviceList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_small"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/footer_message"
            android:textColor="@color/app_text_secondary"
            android:textSize="@dimen/text_caption" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/privacyLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/privacy_policy"
                android:textColor="@color/app_text_secondary"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_small"
                android:paddingEnd="@dimen/spacing_small"
                android:text="@string/footer_separator"
                android:textColor="@color/app_text_secondary"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/aboutLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/about"
                android:textColor="@color/app_text_secondary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/finderPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_gutter"
        android:paddingTop="@dimen/spacing_medium"
        android:paddingEnd="@dimen/screen_gutter"
        android:paddingBottom="@dimen/spacing_medium"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/finder_title"
            android:textColor="@color/app_text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/finderDeviceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:gravity="center"
            android:textColor="@color/app_text_primary"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/finderDeviceAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="@color/app_text_secondary"
            android:textSize="@dimen/text_secondary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            app:cardBackgroundColor="@color/app_surface"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:id="@+id/finderSignalLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/signal_unavailable"
                    android:textColor="@color/app_text_primary"
                    android:textSize="@dimen/text_signal"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/finderSignalValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:gravity="center"
                    android:text="@string/signal_dash"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="@dimen/text_body" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/finderSignalProgress"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:max="100"
                    android:progress="0"
                    app:indicatorColor="@color/app_primary"
                    app:trackColor="@color/app_primary_container"
                    app:trackCornerRadius="4dp" />

                <TextView
                    android:id="@+id/finderWaitingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:gravity="center"
                    android:text="@string/finder_waiting"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="@dimen/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_medium"
            android:layout_weight="1"
            android:gravity="top"
            android:text="@string/finder_description"
            android:textColor="@color/app_text_secondary"
            android:textSize="@dimen/text_body" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/finderScanButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/stop_scan"
            android:textSize="@dimen/text_button"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backToDevicesButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_small"
            android:text="@string/back_to_devices"
            android:textSize="@dimen/text_button"
            app:cornerRadius="24dp" />
    </LinearLayout>

</FrameLayout>
